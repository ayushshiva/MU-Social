rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    function isValidImage() {
      return request.resource.contentType.matches('image/.*')
             && request.resource.size < 5 * 1024 * 1024; // 5MB limit
    }

    function isValidVideo() {
      return request.resource.contentType.matches('video/.*')
             && request.resource.size < 50 * 1024 * 1024; // 50MB limit
    }

    // --- User Folders ---
    match /users/{userId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isOwner(userId)
                    && (isValidImage() || isValidVideo());
    }

    // --- Posts Media ---
    match /posts/{userId}/{postId}/{fileName} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(userId)
                    && (isValidImage() || isValidVideo());
      allow update: if false; // Prevent overwriting. Delete and re-upload if needed.
      allow delete: if isSignedIn() && (isOwner(userId) || isAdmin());
    }

    // --- Stories ---
    match /stories/{userId}/{storyId}/{fileName} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(userId)
                    && (isValidImage() || isValidVideo())
                    && request.resource.size < 2 * 1024 * 1024; // 2MB limit for stories
      allow delete: if isSignedIn() && (isOwner(userId) || isAdmin());
    }

    // --- Reels ---
    match /reels/{userId}/{reelId}/{fileName} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(userId)
                    && isValidVideo();
      allow delete: if isSignedIn() && (isOwner(userId) || isAdmin());
    }

    // --- Chat Attachments ---
    match /chats/{chatId}/{fileName} {
      allow read: if isSignedIn() && firestore.get(/databases/(default)/documents/chats/$(chatId)).data.participants.hasAny([request.auth.uid]);
      allow create: if isSignedIn()
                    && firestore.get(/databases/(default)/documents/chats/$(chatId)).data.participants.hasAny([request.auth.uid])
                    && (isValidImage() || request.resource.size < 10 * 1024 * 1024); // 10MB limit
    }
  }
}
